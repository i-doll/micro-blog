# ---------------------------------------------------------------
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# .env is gitignored and will NOT be committed.
# docker-compose reads .env automatically.
# For local dev (outside Docker), export these or use direnv/dotenv.
# ---------------------------------------------------------------

# PostgreSQL root password (used by all service DB connection strings)
POSTGRES_PASSWORD=change_me

# Captcha signing secret (used by captcha-service, gateway, and auth-service)
# Generate with: openssl rand -hex 32
CAPTCHA_SECRET=change_me

# CORS allowed origins (comma-separated)
# Local dev: frontend + gateway origins so the browser can reach the API.
CORS_ORIGINS=http://localhost:3007,http://localhost:3000

# Trusted reverse proxy IPs (comma-separated, optional)
# When set, the gateway reads X-Forwarded-For only from these peers.
# When unset (default), XFF is ignored and the socket address is used.
# TRUSTED_PROXIES=10.0.0.1,10.0.0.2

# Admin bootstrap (optional — set to create an admin user at startup)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change_me
# ADMIN_USERNAME=admin
